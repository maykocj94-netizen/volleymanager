{
  "name": "volley-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Volley Manager — jogo de gerenciamento de vôlei de praia e quadra (PWA).",
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "play": "node scripts/dev.mjs",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:web:open": "npm run dev:open --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir apps/api --port 8000",
    "db:schema": "echo 'Apply db/schema.sql to your Postgres/Supabase instance'"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
