# Banco (Supabase: Project Settings → Database → Connection string, modo "session")
# Use o driver asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres:senha@db.xxxx.supabase.co:5432/postgres

# Supabase Auth — para validar o JWT do usuário
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_JWT_SECRET=seu-jwt-secret-do-supabase
SUPABASE_SERVICE_ROLE_KEY=service-role-key   # operações privilegiadas (opcional)

# App
ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
